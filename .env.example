# RPC URLs (optional — falls back to public RPCs if not set)
# Public RPCs work fine and support larger getLogs ranges than Alchemy free tier.
RPC_URL_MAINNET=
RPC_URL_BASE=
RPC_URL_ARBITRUM=
RPC_URL_UNICHAIN=

# Webhook URL for new auction alerts (optional)
# Supports Slack, Discord, or any endpoint accepting JSON POST
WEBHOOK_URL=

# Telegram bot and channel IDs (optional — needed for alerts and bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PREMIUM_CHANNEL_ID=
TELEGRAM_PUBLIC_CHANNEL_ID=

# Extra RSS/Atom feeds for intent radar (optional, comma-separated)
INTENT_FEEDS=

# Article link (optional) — shown in bot /start and /stats when set
ARTICLE_URL=

# Post-graduation price tracking via DexScreener (default: false)
# When true: alerts on -10/-20/-30% moves, premium channel only, 24h cooldown
TRACK_POST_GRADUATION=

# Set SKIP_RPC=1 to skip online tests (offline golden tests still run)
SKIP_RPC=
