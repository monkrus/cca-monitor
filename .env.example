# RPC URLs (optional — falls back to public RPCs if not set)
# Public RPCs work fine and support larger getLogs ranges than Alchemy free tier.
# If you want a dedicated key, Infura/Ankr/dRPC all have generous free tiers.
RPC_URL_MAINNET=
RPC_URL_BASE=
RPC_URL_ARBITRUM=
RPC_URL_UNICHAIN=

# Webhook URL for new auction alerts (optional)
# Supports Slack, Discord, or any endpoint accepting JSON POST
WEBHOOK_URL=

# Telegram bot alerts (optional)
# Create a bot via @BotFather, send it /start, then get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PREMIUM_CHANNEL_ID=
TELEGRAM_PUBLIC_CHANNEL_ID=
SUBSCRIPTION_PRICE_STARS=250
SUBSCRIPTION_DAYS=30
